---
const navItems = [
    { href: "#home", icon: "fa-home", label: "Home" },
    { href: "#about", icon: "fa-heart", label: "About" },
    { href: "#hobbies", icon: "fa-star", label: "Hobbies" },
    { href: "#gallery", icon: "fa-images", label: "Gallery" },
    { href: "#games", icon: "fa-gamepad", label: "Games" },
];

const tags = [
    "Dreamer ☁️",
    "Coffee Lover ☕",
    "Bookworm 📚",
    "Cat Person 🐱",
    "Sunshine Collector ☀️",
];

const hobbies = [
    {
        icon: "fa-book-open",
        title: "Reading",
        text: "I read a lot, be it scientific journals, the news, or just novels, I love them all!",
    },
    {
        icon: "fa-cookie-bite",
        title: "Baking & Cooking",
        text: "Making cute pastries and sharing them with friends.",
    },
    {
        icon: "fa-camera",
        title: "Photography",
        text: "Capturing moments that spark joy (although I am not good at it)",
    },
    {
        icon: "fa-music",
        title: "Music",
        text: "Music is the best thing in the world!",
    },
    {
        icon: "fa-gamepad",
        title: "Games",
        text: "I play a lot of games from a lot of different genres, scroll down to learn more!",
    },
];

const galleryIcons = [
    "fa-mug-hot",
    "fa-book",
    "fa-palette",
    "fa-leaf",
    "fa-moon",
    "fa-rainbow",
];

const games = [
    {
        theme: "pink",
        icon: "🎀",
        title: "League of Legends",
        text: "Proud Zeri main",
        tags: ["MOBA ⚔️", "Team Play 👥", "Competitive 🏆"],
        statusIcon: "fa-heart",
        status: "Peak plat •",
        float: "🌸",
    },
    {
        theme: "blue",
        icon: "✨",
        title: "Genshin Impact",
        text: "Exploring beautiful landscapes and collecting characters! My favorite character is Mualani 🐟",
        tags: ["Adventure 🗺️", "Gacha 🎴", "Open World 🌍"],
        statusIcon: "fa-star",
        status: "AR 60 •",
        float: "⭐",
    },
    {
        theme: "green",
        icon: "🍄",
        title: "Terraria",
        text: "Peak game!!! Definitely try the calamity mod if you havent!",
        tags: ["Cozy 🏡", "RPG ⚔️", "Adventure 🗺️"],
        statusIcon: "fa-leaf",
        status: "100% achievements •",
        float: "🌿",
    },
];

const stats = [
    { icon: "🎮", label: "Total Games Played", value: "250+", color: "pink" },
    { icon: "⏰", label: "Total Playtime", value: "too much", color: "blue" },
    {
        icon: "❤️",
        label: "Favorite Genre",
        value: "Games that I can nerd out about",
        color: "green",
    },
    {
        icon: "🏆",
        label: "Highest Achievement",
        value: "Terraria infernum",
        color: "purple",
    },
];

const songs = [
    {
        title: "Primadonna",
        artist: "MARINA",
        file: "/music/Primadonna.mp3",
        color: "#ffb8e2",
    },
    {
        title: "Buriki No Dance",
        artist: "Ado",
        file: "/music/Adoブリキノダンス 歌いました.mp3",
        color: "#ffb8e2",
    },
    {
        title: "girlfailure.",
        artist: "ISSBROKIE",
        file: "/music/girlfailure..mp3",
        color: "#ffb8e2",
    },
    {
        title: "Thanatosis",
        artist: "DAMNED",
        file: "/music/DAMNED -Thanatosis- Official Music Video [96rcpVrGzCY].mp3",
        color: "#ffb8e2",
    },
    {
        title: "SPAGHETTI",
        artist: "LE SSERAFIM",
        file: "/music/LE SSERAFIM (르세라핌) 'SPAGHETTI (feat. j-hope of BTS)' OFFICIAL MV.mp3",
        color: "#ffb8e2",
    },
];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta
            name="description"
            content="Splinters' cozy corner: hobbies, games, music, and little joys."
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Comic+Neue:wght@300;400;700&family=Nunito:wght@300;400;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
        />
        <title>Splinters ✨ | Cozy Corner</title>
    </head>
    <body>
        <div
            id="disclaimerModal"
            class="disclaimer-overlay"
            role="dialog"
            aria-modal="true"
            aria-labelledby="disclaimerTitle"
            aria-describedby="disclaimerCopy"
        >
            <div class="disclaimer-card">
                <div class="disclaimer-icon" aria-hidden="true">⚠️</div>
                <p class="disclaimer-kicker">Please read before continuing</p>
                <h1 id="disclaimerTitle">Trans Rights Are Human Rights</h1>
                <div id="disclaimerCopy" class="disclaimer-copy">
                    <p id="disclaimerMessage">Trans rights are human rights.</p>
                </div>
                <div class="disclaimer-actions">
                    <button
                        id="agreeDisclaimer"
                        class="disclaimer-button disclaimer-agree"
                        type="button"
                    >
                        I Agree
                    </button>
                    <button
                        id="declineDisclaimer"
                        class="disclaimer-button disclaimer-decline"
                        type="button"
                    >
                        I Don’t Agree
                    </button>
                </div>
            </div>
        </div>

        <div class="emoji-layer" aria-hidden="true"></div>

        <header class="site-header">
            <div class="container">
                <nav class="cloud-nav" aria-label="Main navigation">
                    {
                        navItems.map((item) => (
                            <a href={item.href} class="nav-btn">
                                <i
                                    class={`fas ${item.icon}`}
                                    aria-hidden="true"
                                />
                                {item.label}
                            </a>
                        ))
                    }
                </nav>
            </div>
        </header>

        <main>
            <section id="home" class="hero">
                <div class="container">
                    <div class="hero-content">
                        <div class="profile-pic">
                            <img
                                src="/assets/mualani-genshin-impact.gif"
                                alt="Animated Mualani profile picture"
                            />
                        </div>
                        <h1>Hi, I'm Splinters! 🌸</h1>
                        <p class="cute-title">
                            A cozy soul who loves little joys and big dreams ✨
                        </p>

                        <div class="tag-cloud" aria-label="Personal tags">
                            {tags.map((tag) => <span class="tag">{tag}</span>)}
                        </div>
                    </div>
                </div>
            </section>

            <section id="about" class="section section-pink">
                <div class="container">
                    <h2 class="section-title">About Me 🎀</h2>
                    <div class="about-card">
                        <p class="intro-copy">
                            Hello there! I'm Splinters, a Trans woman from
                            Belgium. I find happiness in small things, like
                            talking to friends or listening to music 💖
                        </p>
                        <p>My days are filled with:</p>
                        <ul class="joy-list">
                            <li>🌸 Morning cup of coffee</li>
                            <li>📸 Taking pictures of my pets</li>
                            <li>📞 Calling with my friends</li>
                            <li>✨ Finding new songs for my playlist</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section id="hobbies" class="section">
                <div class="container">
                    <h2 class="section-title">My Happy Things 🎨</h2>
                    <div class="hobbies-grid">
                        {
                            hobbies.map((hobby) => (
                                <article class="hobby-card">
                                    <i
                                        class={`fas ${hobby.icon}`}
                                        aria-hidden="true"
                                    />
                                    <h3>{hobby.title}</h3>
                                    <p>{hobby.text}</p>
                                </article>
                            ))
                        }
                    </div>
                </div>
            </section>

            <section id="gallery" class="section section-blue">
                <div class="container">
                    <h2 class="section-title">My Cozy Corner 📸</h2>
                    <div class="gallery-grid">
                        {
                            galleryIcons.map((icon) => (
                                <div class="gallery-item">
                                    <i
                                        class={`fas ${icon}`}
                                        aria-hidden="true"
                                    />
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <section id="games" class="section section-soft-blue">
                <div class="container">
                    <h2 class="section-title">Games I Love 🎮✨</h2>
                    <div class="games-grid">
                        {
                            games.map((game) => (
                                <article
                                    class={`game-card game-card-${game.theme}`}
                                >
                                    <div class="game-icon">{game.icon}</div>
                                    <h3>{game.title}</h3>
                                    <p>{game.text}</p>
                                    <div class="game-tags">
                                        {game.tags.map((tag, index) => (
                                            <span
                                                class={`game-tag game-tag-${index}`}
                                            >
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                    <div class="game-status">
                                        <i
                                            class={`fas ${game.statusIcon}`}
                                            aria-hidden="true"
                                        />
                                        <span>{game.status}</span>
                                    </div>
                                    <div class="game-float" aria-hidden="true">
                                        {game.float}
                                    </div>
                                </article>
                            ))
                        }
                    </div>

                    <div class="game-stats">
                        <h3>My Gaming Stats 📊</h3>
                        <div class="stats-grid">
                            {
                                stats.map((stat) => (
                                    <div class={`stat-card stat-${stat.color}`}>
                                        <div class="stat-icon">{stat.icon}</div>
                                        <div class="stat-label">
                                            {stat.label}
                                        </div>
                                        <div class="stat-value">
                                            {stat.value}
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <div class="floating-player">
            <button
                class="player-toggle"
                type="button"
                aria-label="Open music player"
            >
                <i class="fas fa-music" aria-hidden="true"></i>
                <span class="music-note" aria-hidden="true">🎵</span>
            </button>

            <div class="player-popup" aria-label="Music player">
                <button
                    class="close-player"
                    type="button"
                    aria-label="Close music player"
                >
                    <i class="fas fa-times" aria-hidden="true"></i>
                </button>

                <div class="song-row">
                    <div class="album-art">
                        <i class="fas fa-headphones" aria-hidden="true"></i>
                    </div>
                    <div>
                        <h4>Now Playing ✨</h4>
                        <p id="miniSongTitle">Select a song</p>
                        <p id="miniSongArtist">Click play to start</p>
                    </div>
                </div>

                <div class="progress-wrap">
                    <div class="time-row">
                        <span id="miniCurrentTime">0:00</span>
                        <span id="miniTotalTime">0:00</span>
                    </div>
                    <div id="miniProgressContainer" class="progress-container">
                        <div id="miniProgressBar" class="progress-bar"></div>
                    </div>
                </div>

                <div class="player-controls">
                    <button
                        id="miniPrevBtn"
                        class="mini-btn"
                        type="button"
                        aria-label="Previous song"
                    >
                        <i class="fas fa-step-backward" aria-hidden="true"></i>
                    </button>
                    <button
                        id="miniPlayBtn"
                        class="mini-btn play-btn"
                        type="button"
                        aria-label="Play or pause"
                    >
                        <i class="fas fa-play" aria-hidden="true"></i>
                    </button>
                    <button
                        id="miniNextBtn"
                        class="mini-btn"
                        type="button"
                        aria-label="Next song"
                    >
                        <i class="fas fa-step-forward" aria-hidden="true"></i>
                    </button>
                </div>

                <label class="volume-row" for="miniVolume">
                    <i class="fas fa-volume-up" aria-hidden="true"></i>
                    <input
                        type="range"
                        id="miniVolume"
                        min="0"
                        max="100"
                        value="70"
                    />
                    <span id="miniVolumeValue">70%</span>
                </label>
            </div>
        </div>

        <footer>
            <div class="container">
                <p class="footer-lead">
                    Thank you for visiting my little corner of the internet!
                </p>
                <p>
                    Remember: You're as wonderful as a field of flowers in
                    springtime 🌼
                </p>
                <p>
                    Made with <span class="heart">💖</span> and lots of troubleshooting
                </p>
                <p class="copyright">© Splinters • 2025</p>
            </div>
        </footer>

        <script define:vars={{ songs }}>
            const getElement = (id) => document.getElementById(id);
            const disclaimerModal = getElement("disclaimerModal");
            const agreeDisclaimer = getElement("agreeDisclaimer");
            const disclaimerTitle = getElement("disclaimerTitle");
            const disclaimerMessage = getElement("disclaimerMessage");
            const disclaimers = [
                {
                    title: "Trans Rights Are Human Rights",
                    message: "Trans rights are human rights.",
                },
                {
                    title: "Kill the rich",
                    message: "There are no ethical billionaires",
                },
                {
                    title: "No one is illegal on stolen land",
                    message: "Fuck ICE, fuck Trump and way more",
                },
                {
                    title: "Right wingers/centrists are not welcome here",
                    message:
                        'if you tried to click "I disagree", to any of these I pray you grow up and get some common sense, if not I\'d be crack a smile if you were to die <3',
                },
            ];
            let currentDisclaimer = 0;

            document.body.classList.add("disclaimer-open");
            agreeDisclaimer?.focus();

            agreeDisclaimer?.addEventListener("click", () => {
                currentDisclaimer += 1;

                if (currentDisclaimer < disclaimers.length) {
                    const nextDisclaimer = disclaimers[currentDisclaimer];
                    disclaimerTitle.textContent = nextDisclaimer.title;
                    disclaimerMessage.textContent = nextDisclaimer.message;
                    disclaimerModal?.querySelector(".disclaimer-card")?.animate(
                        [
                            {
                                opacity: 0,
                                transform: "translateY(18px) scale(0.98)",
                            },
                            { opacity: 1, transform: "translateY(0) scale(1)" },
                        ],
                        { duration: 300, easing: "ease-out" },
                    );
                    return;
                }

                disclaimerModal?.classList.add("is-dismissed");
                document.body.classList.remove("disclaimer-open");
            });

            disclaimerModal?.addEventListener("keydown", (event) => {
                if (event.key === "Escape") event.preventDefault();
            });

            document.querySelectorAll(".nav-btn").forEach((anchor) => {
                anchor.addEventListener("click", (event) => {
                    event.preventDefault();
                    document
                        .querySelector(anchor.getAttribute("href"))
                        ?.scrollIntoView({ behavior: "smooth" });
                });
            });

            document.addEventListener("DOMContentLoaded", () => {
                addHeroEmojis();
                addGalleryHover();
                window.player = new SimpleMusicPlayer(songs);
                addFloatingNotes();
            });

            function addHeroEmojis() {
                const emojis = [
                    "🌸",
                    "✨",
                    "🎀",
                    "💝",
                    "💖",
                    "🍰",
                    "🐱",
                    "📚",
                    "☁️",
                    "🌈",
                ];
                const layer = document.querySelector(".emoji-layer");
                if (!layer) return;

                for (let index = 0; index < 22; index++) {
                    const emoji = document.createElement("div");
                    emoji.textContent =
                        emojis[Math.floor(Math.random() * emojis.length)];
                    emoji.className = "floating-emoji";
                    emoji.style.left = `${Math.random() * 100}%`;
                    emoji.style.setProperty(
                        "--start-y",
                        `${Math.random() * 100}vh`,
                    );
                    emoji.style.setProperty(
                        "--drift-x",
                        `${Math.random() * 42 - 21}vw`,
                    );
                    emoji.style.setProperty(
                        "--drift-y",
                        `${Math.random() * 34 - 17}vh`,
                    );
                    emoji.style.fontSize = `${Math.random() * 18 + 18}px`;
                    emoji.style.animationDuration = `${Math.random() * 8 + 9}s`;
                    emoji.style.animationDelay = `${Math.random() * -12}s`;
                    layer.appendChild(emoji);
                }
            }

            function addGalleryHover() {
                document.querySelectorAll(".gallery-item").forEach((item) => {
                    const original = item.innerHTML;
                    item.addEventListener("mouseenter", () => {
                        const emojis = ["💖", "✨", "🌸", "🎨", "📸", "🍵"];
                        item.textContent =
                            emojis[Math.floor(Math.random() * emojis.length)];
                    });
                    item.addEventListener("mouseleave", () => {
                        item.innerHTML = original;
                    });
                });
            }

            class SimpleMusicPlayer {
                constructor(songList) {
                    this.songs = songList;
                    this.audio = new Audio();
                    this.audio.volume = 0.7;
                    this.audio.preload = "metadata";
                    this.isPlaying = false;
                    this.currentSong = 0;
                    this.bindEvents();
                    this.bindAudioEvents();
                    this.loadSong(0);
                }

                bindAudioEvents() {
                    this.audio.addEventListener("timeupdate", () =>
                        this.updateProgress(),
                    );
                    this.audio.addEventListener("loadedmetadata", () =>
                        this.updateProgress(),
                    );
                    this.audio.addEventListener("ended", () => this.next());
                    this.audio.addEventListener("error", () =>
                        this.handlePlayError(),
                    );
                }

                bindEvents() {
                    document
                        .querySelector(".player-toggle")
                        ?.addEventListener("click", (event) => {
                            const popup =
                                document.querySelector(".player-popup");
                            if (!popup) return;
                            popup.classList.toggle("is-open");
                            event.stopPropagation();
                        });

                    document
                        .querySelector(".close-player")
                        ?.addEventListener("click", () => {
                            document
                                .querySelector(".player-popup")
                                ?.classList.remove("is-open");
                        });

                    getElement("miniPlayBtn")?.addEventListener("click", () =>
                        this.togglePlay(),
                    );
                    getElement("miniNextBtn")?.addEventListener("click", () =>
                        this.next(),
                    );
                    getElement("miniPrevBtn")?.addEventListener("click", () =>
                        this.previous(),
                    );

                    getElement("miniVolume")?.addEventListener(
                        "input",
                        (event) => {
                            this.audio.volume = event.target.value / 100;
                            getElement("miniVolumeValue").textContent =
                                `${event.target.value}%`;
                        },
                    );

                    getElement("miniProgressContainer")?.addEventListener(
                        "click",
                        (event) => {
                            if (!this.audio.duration) return;
                            const rect =
                                event.currentTarget.getBoundingClientRect();
                            const percent =
                                (event.clientX - rect.left) / rect.width;
                            this.audio.currentTime =
                                percent * this.audio.duration;
                        },
                    );
                }

                loadSong(index) {
                    if (index < 0 || index >= this.songs.length) return;
                    this.currentSong = index;
                    const song = this.songs[index];
                    getElement("miniSongTitle").textContent = song.title;
                    getElement("miniSongArtist").textContent = song.artist;
                    document.querySelector(".album-art").style.background =
                        `linear-gradient(135deg, ${song.color}, ${this.lightenColor(song.color, 30)})`;
                    this.audio.src = encodeURI(song.file);
                    this.audio.load();
                }

                togglePlay() {
                    if (this.isPlaying) {
                        this.pause();
                        return;
                    }
                    this.play();
                }

                play() {
                    this.audio
                        .play()
                        .then(() => {
                            this.isPlaying = true;
                            this.updatePlayButton();
                        })
                        .catch(() => this.handlePlayError());
                }

                pause() {
                    this.audio.pause();
                    this.isPlaying = false;
                    this.updatePlayButton();
                }

                next() {
                    this.loadSong((this.currentSong + 1) % this.songs.length);
                    if (this.isPlaying) this.play();
                }

                previous() {
                    this.loadSong(
                        (this.currentSong - 1 + this.songs.length) %
                            this.songs.length,
                    );
                    if (this.isPlaying) this.play();
                }

                updateProgress() {
                    if (!this.audio.duration) return;
                    getElement("miniProgressBar").style.width =
                        `${(this.audio.currentTime / this.audio.duration) * 100}%`;
                    getElement("miniCurrentTime").textContent = this.formatTime(
                        this.audio.currentTime,
                    );
                    getElement("miniTotalTime").textContent = this.formatTime(
                        this.audio.duration,
                    );
                }

                updatePlayButton() {
                    const playBtn = getElement("miniPlayBtn");
                    const icon = playBtn?.querySelector("i");
                    if (!playBtn || !icon) return;
                    icon.className = this.isPlaying
                        ? "fas fa-pause"
                        : "fas fa-play";
                    playBtn.classList.toggle("is-playing", this.isPlaying);
                }

                handlePlayError() {
                    const playBtn = getElement("miniPlayBtn");
                    const icon = playBtn?.querySelector("i");
                    if (!playBtn || !icon) return;
                    icon.className = "fas fa-exclamation-circle";
                    playBtn.title = "Click again to play";
                    setTimeout(() => this.updatePlayButton(), 1600);
                }

                formatTime(seconds) {
                    if (Number.isNaN(seconds)) return "0:00";
                    const minutes = Math.floor(seconds / 60);
                    const remainingSeconds = Math.floor(seconds % 60);
                    return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
                }

                lightenColor(color, percent) {
                    const number = Number.parseInt(color.replace("#", ""), 16);
                    const amount = Math.round(2.55 * percent);
                    const red = Math.min(255, (number >> 16) + amount);
                    const green = Math.min(
                        255,
                        ((number >> 8) & 0x00ff) + amount,
                    );
                    const blue = Math.min(255, (number & 0x0000ff) + amount);
                    return `#${((red << 16) | (green << 8) | blue).toString(16).padStart(6, "0")}`;
                }
            }

            function addFloatingNotes() {
                const notes = ["🎵", "🎶", "🎧", "✨", "🌸"];
                const container = document.querySelector(".floating-player");
                if (!container) return;

                for (let index = 0; index < 3; index++) {
                    const note = document.createElement("div");
                    note.textContent =
                        notes[Math.floor(Math.random() * notes.length)];
                    note.className = "floating-note";
                    note.style.animationDuration = `${3 + index}s`;
                    note.style.animationDelay = `${index}s`;
                    container.appendChild(note);
                }
            }
        </script>
    </body>
</html>

<style is:global>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        scroll-behavior: smooth;
        width: 100%;
    }

    body {
        background: linear-gradient(135deg, #ffe8f5 0%, #e6f3ff 100%);
        color: #6d5a72;
        font-family: "Nunito", sans-serif;
        line-height: 1.8;
        overflow-x: clip;
        width: 100%;
    }

    body.disclaimer-open {
        overflow: hidden;
    }

    .disclaimer-overlay {
        align-items: center;
        backdrop-filter: blur(18px);
        background: rgba(45, 31, 51, 0.82);
        display: flex;
        inset: 0;
        justify-content: center;
        padding: 24px;
        position: fixed;
        z-index: 10000;
    }

    .disclaimer-overlay.is-dismissed {
        display: none;
    }

    .disclaimer-card {
        background: linear-gradient(145deg, #fffafd, #f5f9ff);
        border: 4px solid #ffffff;
        border-radius: 34px;
        box-shadow: 0 30px 90px rgba(20, 10, 25, 0.45);
        max-height: calc(100vh - 48px);
